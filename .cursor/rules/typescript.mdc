# TypeScript 규칙

## 1. 타입 정의 규칙

```ts
// ❌ any 금지
function parse(data: any) { ... }

// ✅ unknown으로 타입 안전성 확보
function parse(data: unknown) {
  if (typeof data === "string") return JSON.parse(data);
  throw new Error("유효하지 않은 데이터 형식");
}

// ✅ 유니온 타입으로 상태 표현
type LoadingState = "idle" | "loading" | "success" | "error";

// ✅ 타입 추론이 명확한 경우 생략 가능
const count = 0;           // number 생략 OK
const name: string = "홍길동"; // 명시 불필요
```

- `strict: true` 모드 필수
- 타입 추론이 명확한 경우에만 생략, 나머지는 명시

## 2. 인터페이스 / 타입 규칙

```ts
// ✅ 인터페이스 - 객체 타입에 사용 (확장 가능)
interface Post {
  readonly id: string;       // readonly 적극 활용
  title: string;
  slug: string;
  publishedAt: string;
  tags: readonly string[];
}

interface DetailedPost extends Post {
  content: string;
  author: Author;
}

// ✅ 타입 별칭 - 유니온/인터섹션에 사용
type PostOrDraft = Post | Draft;
type AdminPost = Post & { isHidden: boolean };

// ✅ 제네릭으로 재사용성 향상
interface ApiResponse<T> {
  data: T;
  status: number;
  message?: string;
}
```

- 네이밍: **PascalCase** 필수
- 객체 구조 → `interface`, 유니온/인터섹션 → `type`

## 3. 타입 가드

```ts
// ✅ is 타입 가드
function isPost(value: unknown): value is Post {
  return (
    typeof value === "object" &&
    value !== null &&
    "id" in value &&
    "title" in value
  );
}

// ✅ instanceof 활용
function handleError(error: unknown): string {
  if (error instanceof Error) return error.message;
  return "알 수 없는 오류가 발생했습니다";
}

// ✅ in 연산자 활용
function processItem(item: Post | Draft) {
  if ("publishedAt" in item) {
    // item은 Post
    return formatDate(item.publishedAt);
  }
  // item은 Draft
  return item.savedAt;
}
```

- `as` 타입 단언보다 **타입 가드 함수** 선호

## 4. 유틸리티 타입

```ts
// Partial - 업데이트 요청 시 선택적 필드
type UpdatePostInput = Partial<Omit<Post, "id" | "publishedAt">>;

// Required - 모든 필드 필수화
type StrictConfig = Required<AppConfig>;

// Pick - 필요한 필드만 선택
type PostSummary = Pick<Post, "id" | "title" | "slug" | "tags">;

// Record - 키-값 매핑
type TagCount = Record<string, number>;
const tagMap: TagCount = { react: 5, nextjs: 3 };

// ReturnType / Parameters - 함수 타입 추론
type GetPostReturn = Awaited<ReturnType<typeof getPost>>;
```

## 5. 타입 단언

```ts
// ❌ 이중 단언 금지
const el = document.getElementById("root") as unknown as HTMLDivElement;

// ❌ non-null 단언 남용 금지
const user = getUser()!;

// ✅ 타입 가드로 안전하게 처리
const el = document.getElementById("root");
if (!(el instanceof HTMLDivElement)) throw new Error("루트 엘리먼트 없음");

// ✅ as const - 리터럴 타입 고정
const ROUTES = {
  HOME: "/",
  BLOG: "/blog",
  ABOUT: "/about",
} as const;

type Route = (typeof ROUTES)[keyof typeof ROUTES]; // "/" | "/blog" | "/about"
```

## 6. 제네릭

```ts
// ✅ 의미 있는 타입 파라미터명 사용
// T: 일반 타입, K: 키, V: 값, E: 에러
async function fetchData<T>(url: string): Promise<T> {
  const res = await fetch(url);
  return res.json() as Promise<T>;
}

// ✅ extends로 제약 조건 부여
function getProperty<T, K extends keyof T>(obj: T, key: K): T[K] {
  return obj[key];
}

// ✅ 기본 타입 지정
interface QueryOptions<T = unknown> {
  enabled?: boolean;
  initialData?: T;
}

// ✅ 조건부 타입
type NonNullable<T> = T extends null | undefined ? never : T;
type Awaited<T> = T extends Promise<infer U> ? U : T;
```

## 7. 모듈 시스템

```ts
// ✅ 타입 import 명시 (번들 최적화)
import type { Post, Author } from "@/types/post";
import { formatDate } from "@/lib/utils/formatDate";

// ✅ 배럴 파일로 외부 API 정리
// src/types/index.ts
export type { Post, Draft, Author } from "./post";
export type { ApiResponse, PaginationMeta } from "./api";

// ❌ 순환 참조 금지
// a.ts → b.ts → a.ts (X)
```

- 네임스페이스 대신 ES 모듈 사용
- 타입만 가져올 때 `import type` 명시

