## 6. API 관련

```ts
// src/lib/api/client.ts - fetch 래퍼 통일
interface FetchOptions extends RequestInit {
  params?: Record<string, string>;
}

export async function notionFetch<T>(
  endpoint: string,
  options: FetchOptions = {}
): Promise<T> {
  const { params, ...init } = options;
  const url = new URL(`${NOTION_API.BASE_URL}${endpoint}`);

  if (params) {
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
  }

  const res = await fetch(url, {
    ...init,
    headers: {
      "Authorization": `Bearer ${env.notionApiKey}`,
      "Notion-Version": NOTION_API.VERSION,
      "Content-Type": "application/json",
      ...init.headers,
    },
    next: { revalidate: 3600 }, // ISR 기본 1시간
  });

  if (!res.ok) {
    throw new Error(`Notion API 오류: ${res.status} ${res.statusText}`);
  }

  return res.json() as Promise<T>;
}
```

- 공통 fetch 클라이언트 하나로 통일, 직접 `fetch` 호출 지양
- API 응답 타입 반드시 정의
- `next: { revalidate }` 옵션으로 캐시 전략 명시

## 7. 유효성 검사 (Zod)

```ts
import { z } from "zod";

// ✅ Zod 스키마로 런타임 검증 + 타입 추론 동시 처리
export const postSchema = z.object({
  id: z.string().min(1),
  title: z.string().min(1, "제목은 필수입니다"),
  slug: z.string().regex(/^[a-z0-9-]+$/, "slug는 소문자, 숫자, 하이픈만 허용합니다"),
  publishedAt: z.string().datetime(),
  tags: z.array(z.string()).default([]),
});

export type Post = z.infer<typeof postSchema>; // 타입 자동 추론

// ✅ 타입 가드 활용
export function isPost(value: unknown): value is Post {
  return postSchema.safeParse(value).success;
}
```

- 에러 메시지 한국어로 일관성 있게 작성
- `safeParse` 사용으로 예외 없이 검증 결과 처리

## 8. 테스트

```ts
// formatDate.test.ts
import { formatDate } from "./formatDate";

describe("formatDate", () => {
  it("ISO 날짜를 한국어 형식으로 변환한다", () => {
    expect(formatDate("2024-01-01T00:00:00Z")).toBe("2024년 1월 1일");
  });

  // 엣지 케이스
  it("잘못된 날짜 형식에서 에러를 던진다", () => {
    expect(() => formatDate("invalid")).toThrow();
  });

  it("윤년 날짜를 올바르게 처리한다", () => {
    expect(formatDate("2024-02-29T00:00:00Z")).toBe("2024년 2월 29일");
  });
});
```

- 단위 테스트 필수, 엣지 케이스 포함
- 테스트 커버리지 **80% 이상** 유지
